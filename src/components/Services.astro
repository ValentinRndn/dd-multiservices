---
const services = [
  {
    title: "Tonte de pelouse",
    description: "Tonte régulière ou ponctuelle, avec ramassage et évacuation de l'herbe coupée.",
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 36h36"/><path d="M12 36v-4a2 2 0 012-2h20a2 2 0 012 2v4"/><circle cx="14" cy="36" r="3"/><circle cx="34" cy="36" r="3"/><path d="M18 30v-6l-4-4"/><path d="M30 30v-8h4l2-4"/><path d="M22 20c0-4 2-8 2-12"/><path d="M20 10c2 2 6 2 8 0"/></svg>`,
  },
  {
    title: "Taille de haies",
    description: "Taille soignée de vos haies, arbustes et bordures pour un extérieur toujours net.",
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 28l14-14"/><path d="M6 22l10-10"/><path d="M22 14l-8 8"/><path d="M16 28h24c2 0 2-2 0-4H26"/><path d="M20 32h18c2 0 2-2 0-4H22"/><path d="M22 36h14c2 0 2-2 0-4H24"/></svg>`,
  },
  {
    title: "Débroussaillage",
    description: "Nettoyage de terrains, talus et espaces envahis par la végétation.",
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M24 42V26"/><path d="M24 26c-6-2-10-10-8-18 4 4 10 5 14 2-2 8 1 14 6 16"/><path d="M16 34c-4 0-8 2-8 2"/><path d="M32 34c4 0 8 2 8 2"/><path d="M20 38c-3 1-6 3-6 3"/><path d="M28 38c3 1 6 3 6 3"/></svg>`,
  },
  {
    title: "Nettoyage de gouttières",
    description: "Vidage et nettoyage complet de vos gouttières pour éviter les engorgements.",
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20l20-12 20 12"/><path d="M10 18v18h28V18"/><path d="M10 22h28"/><path d="M38 22v6l-4 12"/><path d="M30 40l2-6"/><circle cx="34" cy="42" r="2"/></svg>`,
  },
  {
    title: "Enlèvement d'encombrants",
    description: "Débarras de meubles, électroménager et objets volumineux avec évacuation.",
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="20" width="28" height="18" rx="2"/><path d="M34 28h6a2 2 0 012 2v8h-8"/><circle cx="14" cy="40" r="3"/><circle cx="34" cy="40" r="3"/><path d="M34 24l6 4"/><path d="M10 20v-6h18v6"/></svg>`,
  },
  {
    title: "Évacuation déchets verts",
    description: "Ramassage et évacuation de vos déchets verts après intervention ou en prestation seule.",
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 42h12l4-22H14l4 22z"/><path d="M12 20h24"/><path d="M20 20c0-6 4-12 4-12s4 6 4 12"/><path d="M16 20c0-4-2-8 2-12"/><path d="M32 20c0-4 2-8-2-12"/><path d="M20 28h8"/><path d="M19 34h10"/></svg>`,
  },
  {
    title: "Débarras",
    description: "Vidage de garages, caves, greniers et extérieurs. On s'occupe de tout, du tri à l'évacuation.",
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="8" y="10" width="32" height="28" rx="2"/><path d="M8 18h32"/><path d="M20 18v20"/><path d="M28 18v20"/><path d="M16 6h16v4H16z"/><path d="M18 24h4"/><path d="M26 24h4"/></svg>`,
  },
  {
    title: "Petits travaux",
    description: "Petits travaux d'entretien et services pratiques pour votre maison et vos extérieurs.",
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M28 6l-6 6 8 8 6-6a6 6 0 00-8-8z"/><path d="M22 12L8 26l-2 14 14-2 14-14"/><path d="M16 28l4 4"/><path d="M34 34l6 6"/><path d="M36 34l4 0"/><path d="M40 34v6"/></svg>`,
  },
];
---

<section class="py-20 md:py-28 bg-white" id="services">
  <div class="mx-auto max-w-300 px-6">
    <div class="text-center mb-16">
      <p class="section-label mb-3" data-reveal="up">Nos services</p>
      <h2 class="section-title text-3xl md:text-5xl" data-reveal="up" data-delay="1">
        Tout l'entretien extérieur <em>en un seul appel</em>
      </h2>
    </div>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {services.map((s, i) => (
        <div class={`service-card p-8 group ${i % 2 === 0 ? 'service-card--a' : 'service-card--b'}`} data-reveal="up" data-delay={String(i + 1)}>
          <div class="service-icon" set:html={s.icon} />
          <h3 class="text-base font-semibold text-neutral-900 mb-2" style="font-family: var(--font-heading);">{s.title}</h3>
          <p class="text-sm leading-relaxed text-neutral-600">{s.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
