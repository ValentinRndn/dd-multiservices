---
import "../styles/global.css";
import logo from "../assets/images/logo_dd_multiservices.png";
import heroBg from "../assets/images/hero1.jpg";
import Services from "../components/Services.astro";
import BeforeAfter from "../components/BeforeAfter.astro";
import WhyUs from "../components/WhyUs.astro";
import Contact from "../components/Contact.astro";
import Faq from "../components/Faq.astro";
import Footer from "../components/Footer.astro";
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>DD.Multiservices — Entretien espaces verts & multiservices dans le Calvados</title>
    <meta name="description" content="Entretien extérieur à Bayeux et alentours (Calvados, Bessin, Caen). Tonte, taille de haies, débroussaillage, débarras, gouttières." />
    <meta name="keywords" content="entretien jardin Bayeux, tonte pelouse Calvados, taille haies Normandie, débroussaillage Bessin, débarras Bayeux, multiservices Caen, espaces verts Calvados, nettoyage gouttières Bayeux" />
    <meta property="og:title" content="DD.Multiservices — Entretien & multiservices à Bayeux et dans le Calvados" />
    <meta property="og:description" content="Tonte, taille, débroussaillage, débarras et petits travaux autour de Bayeux. Matériel fourni, chantier laissé propre. Devis gratuit." />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "DD.Multiservices",
      "description": "Entretien espaces verts, débarras et multiservices à Bayeux et dans le Calvados",
      "telephone": "+33745270811",
      "email": "DD.Multiservices@gmail.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Bayeux",
        "addressRegion": "Normandie",
        "postalCode": "14400",
        "addressCountry": "FR"
      },
      "areaServed": {
        "@type": "GeoCircle",
        "geoMidpoint": { "@type": "GeoCoordinates", "latitude": 49.2764, "longitude": -0.7024 },
        "geoRadius": "80000"
      },
      "priceRange": "€",
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
        "opens": "08:00",
        "closes": "19:00"
      }
    })} />
  </head>
  <body class="bg-neutral-50 text-neutral-900">

    <!-- ── NAV ── -->
    <nav class="nav">
      <a href="/" class="nav-logo">
        <img src={logo.src} alt="DD.Multiservices" />
        <span>DD.Multiservices</span>
      </a>
      <div class="hidden md:flex items-center gap-8">
        <a href="#services" class="text-sm text-white/70 hover:text-white transition-colors no-underline">Services</a>
        <a href="#realisations" class="text-sm text-white/70 hover:text-white transition-colors no-underline">Réalisations</a>
        <a href="#faq" class="text-sm text-white/70 hover:text-white transition-colors no-underline">FAQ</a>
      </div>
      <a href="#contact" class="nav-cta">Devis gratuit</a>
    </nav>

    <!-- ── HERO ── -->
    <section class="hero" id="hero">
      <div class="hero-bg" style={`background-image: url(${heroBg.src})`}></div>
      <div class="hero-overlay"></div>
      <div class="hero-inner">
        <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/10 px-4 py-1.5 text-xs text-white/70">
          <span class="h-1.5 w-1.5 rounded-full bg-primary animate-pulse"></span>
          Bayeux & alentours — Intervention rapide
        </div>

        <h1 class="hero-title">
          Entretien extérieur,<br />débarras & multiservices<br /><em>à Bayeux et dans le Calvados.</em>
        </h1>

        <p class="hero-description">
          Tonte, taille de haies, débroussaillage, nettoyage de gouttières,
          débarras et évacuation de déchets. Intervention sur Bayeux, le Bessin,
          la Côte de Nacre et jusqu'à Caen. Matériel fourni, chantier laissé propre.
        </p>

        <div class="hero-actions mb-8">
          <a href="#contact" class="btn-primary">
            Demander un devis gratuit
          </a>
          <a href="tel:0745270811" class="btn-secondary">
            07 45 27 08 11
          </a>
        </div>

        <div class="flex items-center gap-5 flex-wrap text-sm text-white/50">
          <span class="flex items-center gap-2">
            <span class="text-primary">&#10003;</span> Matériel fourni
          </span>
          <span class="flex items-center gap-2">
            <span class="text-primary">&#10003;</span> Chantier laissé propre
          </span>
          <span class="flex items-center gap-2">
            <span class="text-primary">&#10003;</span> Évacuation des déchets
          </span>
        </div>
      </div>

    </section>

    <!-- ── SECTIONS ── -->
    <Services />
    <BeforeAfter />
    <WhyUs />
    <Contact />
    <Faq />
    <Footer />

    <!-- ── SCRIPTS ── -->
    <script>
      // Navbar: transparent → solid on scroll
      const nav = document.querySelector('.nav') as HTMLElement;
      function checkScroll() {
        if (window.scrollY > 50) {
          nav.classList.add('scrolled');
        } else {
          nav.classList.remove('scrolled');
        }
      }
      window.addEventListener('scroll', checkScroll, { passive: true });
      checkScroll();

      // Scroll reveal
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.08, rootMargin: '0px 0px -60px 0px' }
      );
      document.querySelectorAll('[data-reveal]').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
